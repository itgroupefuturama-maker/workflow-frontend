import { useEffect, useRef, useState } from 'react';
import { useDispatch, useSelector } from 'react-redux';
import { X } from 'lucide-react';
import type { AppDispatch, RootState } from '../../../../../app/store';
import { fetchDemandeClient } from '../../../../../app/front_office/parametre_specification/demandeClientSlice';

type Props = {
  isOpen: boolean;
  onClose: () => void;
  prestationId: string;
};

const PanneauPreferencesClient = ({ isOpen, onClose, prestationId }: Props) => {
  const dispatch = useDispatch<AppDispatch>();

  const { groupes, loading, error } = useSelector(
    (state: RootState) => state.demandeClient
  );

  const [activeTab, setActiveTab] = useState<number>(1);
  const prevPrestationIdRef = useRef<string>('');
  const shouldResetTabRef = useRef<boolean>(false);

  // ── Détecte le changement de prestationId et déclenche le fetch ──
  if (prestationId && prevPrestationIdRef.current !== prestationId) {
    prevPrestationIdRef.current = prestationId;
    shouldResetTabRef.current = true; // ← marquer pour reset, pas setState direct
  }

  // ── Fetch quand le panneau s'ouvre ──
  useEffect(() => {
    if (isOpen && prestationId) {
      dispatch(fetchDemandeClient(prestationId));
    }
  }, [isOpen]); // ← uniquement quand isOpen change

  // ── Reset onglet après changement de prestationId ──
  useEffect(() => {
    if (shouldResetTabRef.current) {
      shouldResetTabRef.current = false;
      setActiveTab(1);
    }
  }); // ← sans dépendances : s'exécute après chaque render, vérifie le flag

  // ── Fallback si l'onglet actif n'existe plus ──
  useEffect(() => {
    if (groupes.length > 0) {
      const tabExists = groupes.some(g => g.numero === activeTab);
      if (!tabExists) {
        setActiveTab(groupes[0].numero);
      }
    }
  }, [groupes.length]);

  const activeGroupe = groupes.find(g => g.numero === activeTab);

  if (!isOpen) return null;

  return (
    <div className="w-80 xl:w-96 shrink-0 flex flex-col border-l border-neutral-200 bg-white h-full overflow-hidden">

      {/* ── Header ── */}
      <div className="flex items-center justify-between px-4 py-3 border-b border-neutral-200 bg-slate-700 shrink-0">
        <div>
          <p className="text-[9px] font-semibold text-slate-400 uppercase tracking-widest mb-0.5">
            {prestationId.slice(-6).toUpperCase()}
          </p>
          <h2 className="text-xs font-bold text-white">Spécifications client {prestationId}</h2>
        </div>
        <button
          onClick={onClose}
          className="p-1 rounded text-slate-400 hover:text-white hover:bg-slate-600 transition-colors"
        >
          <X className="w-3.5 h-3.5" />
        </button>
      </div>

      {/* ── Onglets ── */}
      {groupes.length > 0 && (
        <div className="shrink-0 flex items-end gap-1 px-3 pt-3 border-b border-neutral-200 bg-neutral-50 overflow-x-auto">
          {groupes.map((groupe) => (
            <button
              key={groupe.numero}
              onClick={() => setActiveTab(groupe.numero)}
              className={`shrink-0 px-3 py-1.5 text-[11px] font-semibold rounded-t-md transition-all border-t border-l border-r ${
                activeTab === groupe.numero
                  ? 'bg-white text-neutral-900 border-neutral-200 -mb-px'
                  : 'bg-transparent text-neutral-500 border-transparent hover:text-neutral-700'
              }`}
            >
              #{groupe.numero}
            </button>
          ))}
        </div>
      )}

      {/* ── Contenu scrollable ── */}
      <div className="flex-1 overflow-y-auto px-4 py-3">

        {/* Loading */}
        {loading && (
          <div className="flex items-center justify-center py-10">
            <div className="w-6 h-6 border-2 border-neutral-200 border-t-slate-700 rounded-full animate-spin" />
          </div>
        )}

        {/* Erreur */}
        {!loading && error && (
          <div className="mt-4 px-3 py-2 bg-red-50 border border-red-200 rounded-lg">
            <p className="text-[11px] text-red-700">{error}</p>
          </div>
        )}

        {/* Vide */}
        {!loading && !error && groupes.length === 0 && (
          <div className="flex flex-col items-center justify-center py-12 text-center">
            <div className="w-8 h-8 rounded-full bg-neutral-100 flex items-center justify-center mb-3">
              <X className="w-4 h-4 text-neutral-400" />
            </div>
            <p className="text-xs font-medium text-neutral-500">Aucune spécification</p>
            <p className="text-[11px] text-neutral-400 mt-1">Aucune donnée enregistrée pour ce dossier</p>
          </div>
        )}

        {/* Contenu de l'onglet actif */}
        {!loading && !error && activeGroupe && (
          <div className="space-y-2 pt-1">

            {/* Compteur */}
            <div className="flex items-center justify-between mb-3">
              <p className="text-[10px] font-bold text-neutral-400 uppercase tracking-wider">
                Demande #{activeGroupe.numero}
              </p>
              <span className="text-[10px] bg-neutral-100 text-neutral-500 px-2 py-0.5 rounded-full font-mono">
                {activeGroupe.items.length} élément(s)
              </span>
            </div>

            {/* Items */}
            {activeGroupe.items.map((item) => (
              <div
                key={item.id}
                className="bg-neutral-50 border border-neutral-200 rounded-lg px-3 py-2.5"
              >
                {/* Nom attribut */}
                <p className="text-[10px] font-bold text-neutral-500 uppercase tracking-wide mb-1">
                  {item.demandeClientAttribut.nom}
                </p>

                {/* Valeur */}
                <div className="flex items-center justify-between gap-2">
                  <span className="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-slate-700 text-white">
                    {item.valeur}
                  </span>
                  <span className="text-[10px] font-mono text-neutral-400">
                    {item.demandeClientAttribut.type}
                  </span>
                </div>

                {/* valeurType — options possibles */}
                {item.demandeClientAttribut.valeurType && (
                  <div className="flex flex-wrap gap-1 mt-2">
                    {item.demandeClientAttribut.valeurType
                      .split('#')
                      .filter(Boolean)
                      .map((opt) => (
                        <span
                          key={opt}
                          className={`text-[10px] px-1.5 py-0.5 rounded font-mono ${
                            opt === item.valeur
                              ? 'bg-slate-700 text-white'
                              : 'bg-neutral-100 text-neutral-400'
                          }`}
                        >
                          {opt}
                        </span>
                      ))}
                  </div>
                )}
              </div>
            ))}
          </div>
        )}

        <div className="h-4" />
      </div>
    </div>
  );
};

export default PanneauPreferencesClient;